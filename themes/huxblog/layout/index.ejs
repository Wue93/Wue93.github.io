---
layout: page
---
<!-- Main Content -->

<%
var homeProjectData = site.data.projects || {};
var homeAtlasProject = (homeProjectData.experiments || []).filter(function(project){
    return project.sync_map;
})[0];
%>

<% if(homeAtlasProject) { %>
<a class="home-ai-curation" href="<%= homeAtlasProject.link %>" aria-label="进入<%= homeAtlasProject.title %>">
    <span class="home-ai-curation__meta">AI 策展 · <%= homeAtlasProject.type %></span>
    <span class="home-ai-curation__main">
        <strong><%= homeAtlasProject.title %></strong>
        <small><%= homeAtlasProject.description %></small>
    </span>
    <span class="home-ai-curation__action">进入地图 <i aria-hidden="true">→</i></span>
</a>
<% } %>

<ul id="Tabs" class="nav nav-tabs">
    <%
    var tabs = [
        { id: 'all', label: '全部' },
        { id: 'work', label: '职业思考', category: 'Work' },
        { id: 'life', label: '生活感悟', category: 'Life' }
    ];
    var post_list = {};
    var all_posts = site.posts.sort('date').reverse().toArray();

    all_posts.forEach(function(post){
        var category = post.categories && post.categories.data && post.categories.data[0]
            ? post.categories.data[0].name
            : '';
        if (category) {
            if (post_list[category] === undefined) {
                post_list[category] = [];
            }
            post_list[category].push(post);
        }
    });

    function renderPost(post) {
    %>
        <div class="post-preview">
            <a href="<%- config.root %><%- post.path %>">
                <h2 class="post-title">
                    <%- post.title || "Untitled" %>
                </h2>
                <h3 class="post-subtitle">
                    <%- post.subtitle || "" %>
                </h3>
                <div class="post-content-preview">
                    <%- truncate(strip_html(post.content).replace(/\s+/g, ''), {length: 110, omission: '...'}) %>
                </div>
            </a>
            <p class="post-meta">
                Posted by <%- post.author || config.author %> on
                <%= post.date.format(config.date_format) %>
            </p>
        </div>
    <%
    }
    %>
    <% tabs.forEach(function(tab, index){ %>
        <li class="<%= index === 0 ? 'active' : '' %>">
            <a href="#<%- tab.id %>" data-toggle="tab">
                <%- tab.label %>
            </a>
        </li>
    <% }); %>
</ul>

<div id="Contents" class="tab-content">
    <% tabs.forEach(function(tab, index){ %>
        <div class="tab-pane fade <%= index === 0 ? 'in active' : '' %>" id="<%- tab.id %>">
            <%
            var posts = tab.category ? (post_list[tab.category] || []) : all_posts;
            posts.forEach(function(post){
                renderPost(post);
            });
            %>
        </div>
    <% }); %>
</div>



<!-- Pager -->

<ul class="pager">
    <% if (page.prev){ %>
        <li class="previous">
            <a href="<%- config.root %><%- page.prev_link %>">&larr; Newer Posts</a>
        </li>
    <% } %>
    <% if (page.next){ %>
        <li class="next">
            <a href="<%- config.root %><%- page.next_link %>">Older Posts &rarr;</a>
        </li>
    <% } %>
</ul>

