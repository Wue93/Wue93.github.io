---
layout: layout
---

<!-- Page Header -->
<header class="intro-header inner-hero" style="background-image: url('<%= config.root %><%= page["header-img"] || config["header-img"] %>')">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 col-lg-offset-2 col-md-10 col-md-offset-1 ">
                <div class="site-heading">
                    <h1><%= page.title || config.title %></h1>
                    <span class="subheading"><%= page.description || config.subtitle || "" %></span>
                </div>
            </div>
        </div>
    </div>
</header>

<%
    var bookData = site.data.books || {};
    var years = (bookData.years || []).map(function(year){
        return year;
    }).sort(function(a, b){
        return b.year - a.year;
    });
    var featuredLists = bookData.featuredLists || [];
    var navYears = years;
    function resolveBookCover(cover) {
        if (!cover) return "";
        if (/^(https?:|\/\/|\/)/.test(cover)) return cover;
        return config.root + cover;
    }
%>

<!-- Main Content -->
<div class="container">
    <div class="row">
        <div class="col-lg-10 col-lg-offset-1 col-md-10 col-md-offset-1">
            <section class="books-page">
                <% if(bookData.preview) { %>
                    <div class="books-preview-note">版式预览：当前书目和封面为示例数据</div>
                <% } %>

                <% if(bookData.intro) { %>
                    <p class="books-intro"><%= bookData.intro %></p>
                <% } %>

                <% if(featuredLists.length) { %>
                    <section class="books-featured" aria-labelledby="books-featured-title">
                        <div class="books-featured-heading">
                            <h2 id="books-featured-title">主题书单</h2>
                        </div>

                        <div class="featured-list-grid">
                            <% featuredLists.forEach(function(list){ %>
                                <section class="featured-list">
                                    <div class="featured-list-heading">
                                        <h3><%= list.title %></h3>
                                        <% if(list.note) { %>
                                            <p><%= list.note %></p>
                                        <% } %>
                                    </div>

                                    <div class="featured-book-grid">
                                        <% (list.books || []).forEach(function(book){ %>
                                            <article class="featured-book">
                                                <% if(book.cover) { %>
                                                    <img class="featured-book-cover" src="<%= resolveBookCover(book.cover) %>" alt="《<%= book.title %>》封面">
                                                <% } else { %>
                                                    <div class="featured-book-cover book-cover-fallback" style="--book-color: <%= book.color || '#7FA296' %>;">
                                                        <span class="book-cover-title"><%= book.title %></span>
                                                    </div>
                                                <% } %>
                                                <h4>
                                                    <% if(book.link) { %>
                                                        <a href="<%= book.link %>" target="_blank" rel="noopener"><%= book.title %></a>
                                                    <% } else { %>
                                                        <%= book.title %>
                                                    <% } %>
                                                </h4>
                                            </article>
                                        <% }) %>
                                    </div>
                                </section>
                            <% }) %>
                        </div>
                    </section>
                <% } %>

                <div class="books-annual-heading">
                    <h2>年度书单</h2>
                </div>

                <nav class="books-year-nav" aria-label="年度书单导航">
                    <% navYears.forEach(function(yearGroup){ %>
                        <a href="#books-<%= yearGroup.year %>"><%= yearGroup.year %></a>
                    <% }) %>
                </nav>

                <% years.forEach(function(yearGroup){ %>
                    <section class="book-year-section" id="books-<%= yearGroup.year %>">
                        <div class="book-year-heading">
                            <h3><%= yearGroup.year %></h3>
                            <% if(yearGroup.note) { %>
                                <p><%= yearGroup.note %></p>
                            <% } %>
                        </div>

                        <div class="book-grid">
                            <% (yearGroup.books || []).forEach(function(book){ %>
                                <article class="book-card">
                                    <% if(book.cover) { %>
                                        <img class="book-cover" src="<%= resolveBookCover(book.cover) %>" alt="《<%= book.title %>》封面">
                                    <% } else { %>
                                        <div class="book-cover book-cover-fallback" style="--book-color: <%= book.color || '#7FA296' %>;">
                                            <span class="book-cover-title"><%= book.title %></span>
                                        </div>
                                    <% } %>
                                    <h3>
                                        <% if(book.link) { %>
                                            <a href="<%= book.link %>" target="_blank" rel="noopener"><%= book.title %></a>
                                        <% } else { %>
                                            <%= book.title %>
                                        <% } %>
                                    </h3>
                                    <p><%= book.author %></p>
                                </article>
                            <% }) %>
                        </div>
                    </section>
                <% }) %>
            </section>
        </div>
    </div>
</div>
